# FinSentinel configuration.
# Copy to .env and fill in as needed. yfinance requires no API key.

# Groq API key for the judge agent's override-reasoning LLM call.
# If unset, the judge falls back to deterministic rule-based reasoning.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Alpha Vantage API key (market/fundamental data). https://www.alphavantage.co/support/#api-key
# Not yet wired in — reserved for Phase 2 (Risk/Sentiment/RAG)
ALPHA_VANTAGE_KEY=

# NewsAPI key (news/sentiment ingestion). https://newsapi.org/register
# Not yet wired in — reserved for Phase 2 (Risk/Sentiment/RAG)
NEWSAPI_KEY=

# FRED API key (macroeconomic series). https://fredaccount.stlouisfed.org/apikeys
# Not yet wired in — reserved for Phase 2 (Risk/Sentiment/RAG)
FRED_API_KEY=

# Secret key used to sign auth JWTs. The app boots with an insecure default for
# local dev only — it MUST be overridden with a real random secret in any
# non-local environment, or anyone can forge auth cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Set ENVIRONMENT=production to enforce the JWT secret guard: the app refuses to
# start if JWT_SECRET_KEY is still the insecure dev default. Leave unset/development locally.
ENVIRONMENT=development
